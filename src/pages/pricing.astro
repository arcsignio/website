---
// zh-TW Pricing page — served at /pricing
import BaseLayout from '../layouts/BaseLayout.astro';

const locale = 'zh-TW' as const;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'ArcSign 定價方案',
  description: '比較 ArcSign 免費版與 Pro 版功能。免費版涵蓋完整冷錢包安全功能，Pro 解鎖進階 DeFi 工具。',
  url: 'https://arcsign.io/pricing',
  mainEntity: {
    '@type': 'Product',
    name: 'ArcSign Pro Membership',
    description: '多錢包管理、批次代幣撤銷、最佳路徑 DEX Swap、優先客服支援',
    offers: [
      { '@type': 'Offer', name: 'Free', price: '0', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Pro', price: '30', priceCurrency: 'USD', priceValidUntil: '2027-12-31' },
    ],
  },
};
---

<BaseLayout
  title="ArcSign 定價方案 | 免費 vs Pro USB 冷錢包比較 (2026)"
  description="比較 ArcSign 免費版與 Pro 版。免費：1 個錢包、多鏈支援、DEX Swap。Pro ($30/年)：4+ 錢包、批次撤銷、最佳路徑 Swap、優先客服。無需硬體。"
  locale={locale}
  canonical="https://arcsign.io/pricing"
  schema={schema}
>
  <style>
    .pricing-hero {
      padding: 120px 0 60px;
      text-align: center;
      background: linear-gradient(135deg, rgba(13, 148, 136, 0.08) 0%, rgba(45, 212, 191, 0.04) 100%);
    }
    .pricing-hero h1 {
      font-size: clamp(2rem, 4vw, 3rem);
      margin-bottom: 16px;
    }
    .pricing-hero p {
      color: var(--text-secondary);
      font-size: 1.1rem;
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* Comparison Table */
    .comparison { padding: 60px 0 80px; }
    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 40px;
      font-size: 0.95rem;
    }
    .comparison-table th,
    .comparison-table td {
      padding: 16px 20px;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .comparison-table th:first-child,
    .comparison-table td:first-child {
      text-align: left;
      color: var(--text-secondary);
    }
    .comparison-table thead th {
      font-size: 1.1rem;
      padding-bottom: 24px;
      border-bottom: 2px solid rgba(45, 212, 191, 0.3);
    }
    .comparison-table thead th:nth-child(2) { color: var(--text-primary); }
    .comparison-table thead th:nth-child(3) {
      color: var(--primary);
      position: relative;
    }
    .comparison-table thead th:nth-child(3)::after {
      content: '推薦';
      position: absolute;
      top: -8px;
      right: 8px;
      background: var(--primary);
      color: var(--bg-dark);
      font-size: 0.65rem;
      padding: 2px 8px;
      border-radius: 10px;
      font-weight: 700;
    }
    .comparison-table .price-row td {
      font-size: 1.3rem;
      font-weight: 700;
      padding: 20px;
      border-bottom: 2px solid rgba(45, 212, 191, 0.15);
    }
    .comparison-table .price-row td:nth-child(3) { color: var(--primary); }
    .comparison-table .check { color: var(--success); font-size: 1.2rem; }
    .comparison-table .cross { color: var(--text-secondary); opacity: 0.4; }
    .comparison-table .highlight { color: var(--primary); font-weight: 600; }
    .comparison-table .category-row td {
      font-weight: 700;
      color: var(--text-primary);
      padding-top: 28px;
      border-bottom: 1px solid rgba(45, 212, 191, 0.15);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .pricing-cta-section {
      padding: 60px 0;
      text-align: center;
      background: linear-gradient(135deg, rgba(13, 148, 136, 0.1) 0%, rgba(45, 212, 191, 0.05) 100%);
      border-top: 1px solid rgba(45, 212, 191, 0.1);
    }
    .pricing-cta-section h2 {
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      margin-bottom: 16px;
    }
    .pricing-cta-section p {
      color: var(--text-secondary);
      max-width: 500px;
      margin: 0 auto 32px;
      line-height: 1.7;
    }
    .pricing-cta-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Pricing FAQ */
    .pricing-faq { padding: 80px 0; }
    .pricing-faq h2 {
      text-align: center;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      margin-bottom: 40px;
    }
    .pricing-faq .faq-list { max-width: 720px; margin: 0 auto; }

    @media (max-width: 768px) {
      .comparison-table { font-size: 0.85rem; }
      .comparison-table th, .comparison-table td { padding: 12px 10px; }
      .comparison-table thead th:nth-child(3)::after { display: none; }
    }
  </style>

  <!-- Pricing Hero -->
  <section class="pricing-hero">
    <div class="container">
      <h1><span>選擇適合你的</span><span class="gradient-text">安全方案</span></h1>
      <p>ArcSign 免費版已具備完整冷錢包安全功能。Pro 解鎖進階 DeFi 工具，讓你的資產管理更上一層樓。</p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pricing" style="padding-top: 40px;">
    <div class="container">
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-header">
            <h3>Free</h3>
            <div class="price">
              <span class="price-value">$0</span>
              <span class="price-period">永久免費</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>USB 離線存儲</li>
            <li>1 個錢包</li>
            <li>多鏈支援</li>
            <li>Token Swap</li>
            <li>交易歷史</li>
            <li>自動鎖定</li>
          </ul>
          <a href="/#download" class="btn btn-secondary btn-block">免費下載</a>
        </div>
        <div class="pricing-card featured">
          <div class="pricing-badge">推薦</div>
          <div class="pricing-header">
            <h3>Pro</h3>
            <div class="price">
              <span class="price-value">$30</span>
              <span class="price-period">USDT / 年</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li><strong>所有 Free 功能</strong></li>
            <li><strong>4+ 錢包</strong><span> (每個 NFT +3)</span></li>
            <li>2x 積分加成</li>
            <li>3x 空投權重</li>
            <li>優先客服支援</li>
            <li>未來功能優先體驗</li>
          </ul>
          <a href="/#download" class="btn btn-primary btn-block">升級 Pro</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed Comparison Table -->
  <section class="comparison">
    <div class="container">
      <h2 style="text-align:center;font-size:clamp(1.6rem,3vw,2.2rem);margin-bottom:8px;">功能完整比較</h2>
      <p style="text-align:center;color:var(--text-secondary);margin-bottom:0;">所有安全核心功能免費使用，Pro 解鎖進階 DeFi 工具</p>
      <table class="comparison-table">
        <thead>
          <tr>
            <th>功能</th>
            <th>Free</th>
            <th>Pro</th>
          </tr>
        </thead>
        <tbody>
          <tr class="price-row">
            <td>價格</td>
            <td>$0</td>
            <td>$30 USDT / 年</td>
          </tr>

          <tr class="category-row"><td colspan="3">安全基礎</td></tr>
          <tr>
            <td>USB 離線私鑰存儲</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>XOR 三分片加密</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>mlock 記憶體保護</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>.arcsign 加密備份</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>自動鎖定 + 密碼保護</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>

          <tr class="category-row"><td colspan="3">錢包管理</td></tr>
          <tr>
            <td>錢包數量</td>
            <td>1</td>
            <td class="highlight">4+ (每 NFT +3)</td>
          </tr>
          <tr>
            <td>支援鏈數</td>
            <td>22</td>
            <td>22</td>
          </tr>
          <tr>
            <td>通訊錄</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>交易標籤</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>

          <tr class="category-row"><td colspan="3">DeFi 功能</td></tr>
          <tr>
            <td>DEX Swap</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>Swap 手續費</td>
            <td>0.1%</td>
            <td class="highlight">免費</td>
          </tr>
          <tr>
            <td>最佳路徑自動比價</td>
            <td class="cross">&#10005;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>WalletConnect DApp</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>代幣授權管理</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>批次撤銷授權</td>
            <td class="cross">&#10005;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>跨鏈 NFT 展示</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>
          <tr>
            <td>DeFi 倉位顯示</td>
            <td class="check">&#10003;</td>
            <td class="check">&#10003;</td>
          </tr>

          <tr class="category-row"><td colspan="3">額外權益</td></tr>
          <tr>
            <td>積分加成</td>
            <td>1x</td>
            <td class="highlight">2x</td>
          </tr>
          <tr>
            <td>空投權重</td>
            <td>1x</td>
            <td class="highlight">3x</td>
          </tr>
          <tr>
            <td>客服支援</td>
            <td>社群</td>
            <td class="highlight">優先</td>
          </tr>
          <tr>
            <td>新功能優先體驗</td>
            <td class="cross">&#10005;</td>
            <td class="check">&#10003;</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- CTA -->
  <section class="pricing-cta-section">
    <div class="container">
      <h2>準備好開始了嗎？</h2>
      <p>免費下載 ArcSign，隨時可在 App 內升級 Pro。</p>
      <div class="pricing-cta-buttons">
        <a href="/#download" class="btn btn-primary btn-lg">免費下載</a>
        <a href="/blog/arcsign-pro-nft-membership" class="btn btn-secondary btn-lg">了解 Pro NFT</a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter" id="newsletter">
    <div class="container">
      <div class="newsletter-content">
        <h2>掌握最新動態</h2>
        <p>訂閱 ArcSign 電子報，獲取產品更新、安全教學、DeFi 趨勢與專屬優惠。</p>
        <form class="newsletter-form" id="newsletter-form">
          <input type="email" id="newsletter-email" placeholder="you@example.com" required autocomplete="email" />
          <button type="submit" class="btn btn-primary">免費訂閱</button>
        </form>
        <p class="newsletter-status" id="newsletter-status"></p>
        <p class="newsletter-privacy">不傳送垃圾郵件，隨時可取消訂閱。</p>
      </div>
    </div>
  </section>

  <!-- Pricing FAQ -->
  <section class="pricing-faq">
    <div class="container">
      <h2>定價常見問題</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">
            <span>Pro 會員的 NFT 是什麼？怎麼購買？</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Pro 會員資格以 BSC 鏈上的 <strong>ERC-721 NFT</strong> 形式存在。在 App 內用 USDT/BNB 鑄造即可取得。NFT 是你真正擁有的數位資產，可以轉讓或出售。每個 NFT 有效期 1 年，增加 3 個錢包配額。</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Free 版和 Pro 版的安全等級一樣嗎？</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p><strong>完全一樣。</strong>Free 和 Pro 使用相同的加密引擎（XOR 三分片 + AES-256 + mlock 記憶體保護）。Pro 增加的是 DeFi 效率功能（多錢包、批次撤銷、最佳路徑 Swap），不影響安全等級。</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Swap 手續費怎麼計算？</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Free 用戶：<strong>0.1%</strong> 手續費。Pro 用戶：<strong>完全免費</strong>，還能自動比價多家聚合器，選擇最佳報價路徑。</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>NFT 過期後會怎樣？</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>NFT 過期後降級回 Free 方案，<strong>你的錢包和資產不受影響</strong>。只是無法存取超過 1 個錢包的功能。重新購買 NFT 即可恢復 Pro 權益。</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
