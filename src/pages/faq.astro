---
// zh-TW FAQ page — served at /faq
import BaseLayout from '../layouts/BaseLayout.astro';

const locale = 'zh-TW' as const;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'ArcSign 安全嗎？怎麼確保沒有後門？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ArcSign 採用業界頂級的加密標準保護你的私鑰。最重要的是：私鑰永遠不會離開你的 USB 隨身碟，也不會傳送到任何伺服器。拔掉 USB，駭客就無法存取你的私鑰。',
      },
    },
    {
      '@type': 'Question',
      name: 'ArcSign 和 MetaMask 有什麼不同？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '最大的差別在於私鑰存儲位置。MetaMask 把私鑰存在電腦硬碟，任何能讀取檔案的惡意軟體都可能竊取。ArcSign 把私鑰存在 USB 隨身碟，拔掉就是冷錢包，攻擊者無法存取不存在的檔案。',
      },
    },
    {
      '@type': 'Question',
      name: '如果 USB 壞掉或遺失怎麼辦？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ArcSign 提供兩種備份方式：(1) 助記詞備份：將 12 或 24 個英文單詞抄寫在紙上，多份異地保存。(2) 加密檔案備份：直接複製 USB 內的錢包資料夾到另一個 USB 或安全位置。檔案已加密，只有知道密碼的人才能使用。',
      },
    },
    {
      '@type': 'Question',
      name: 'ArcSign 支援 WalletConnect 嗎？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: '是的，ArcSign 完整支援 WalletConnect。你可以連接到任何支援 WalletConnect 的 dApp，例如 Uniswap、Aave、OpenSea 等。私鑰留在 USB 上，讓你享有冷錢包安全性與熱錢包便利性。',
      },
    },
    {
      '@type': 'Question',
      name: 'ArcSign 是免費的嗎？Pro 方案包含什麼？',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ArcSign 完全免費。Pro 方案（$30/年）提供多錢包管理（每個 NFT +3 個錢包）、批次撤銷代幣授權、2x 積分加成、3x 空投權重與優先客服支援。免費版已涵蓋所有核心錢包功能。',
      },
    },
  ],
};
---

<BaseLayout
  title="ArcSign FAQ: Cold Wallet Security, Setup & DeFi Questions Answered (2026)"
  description="Got questions about ArcSign? We answer the most common ones: How safe is a USB cold wallet? Does it work with WalletConnect? How do I back up my wallet? Read our full FAQ."
  locale={locale}
  canonical="https://arcsign.io/faq"
  schema={schema}
>
  <style>
    .faq-hero {
      padding: 120px 0 60px;
      background: linear-gradient(135deg, #0a0a0a 0%, #0f2b46 100%);
    }
    .faq-hero h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    .faq-content {
      padding: 60px 0;
    }
    .faq-category {
      margin-bottom: 48px;
    }
    .faq-category h2 {
      font-size: 1.5rem;
      margin-bottom: 24px;
      color: #fff;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    .faq-page-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .faq-page-item {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      overflow: hidden;
    }
    .faq-page-question {
      width: 100%;
      padding: 20px 24px;
      background: none;
      border: none;
      color: #fff;
      font-size: 1rem;
      font-weight: 500;
      text-align: left;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: background 0.2s;
    }
    .faq-page-question:hover {
      background: rgba(255, 255, 255, 0.05);
    }
    .faq-page-question .icon {
      font-size: 1.5rem;
      color: rgba(255, 255, 255, 0.5);
      transition: transform 0.3s;
    }
    .faq-page-item.active .faq-page-question .icon {
      transform: rotate(45deg);
    }
    .faq-page-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out;
    }
    .faq-page-item.active .faq-page-answer {
      max-height: 500px;
    }
    .faq-page-answer-content {
      padding: 0 24px 20px;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.8;
    }
    .faq-page-answer-content p {
      margin-bottom: 12px;
    }
    .faq-page-answer-content p:last-child {
      margin-bottom: 0;
    }
    .faq-page-answer-content strong {
      color: #fff;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      margin-bottom: 20px;
      transition: color 0.2s;
    }
    .back-link:hover {
      color: #fff;
    }
    .contact-box {
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
      border: 1px solid rgba(102, 126, 234, 0.3);
      border-radius: 16px;
      padding: 32px;
      text-align: center;
      margin-top: 60px;
    }
    .contact-box h3 {
      font-size: 1.25rem;
      margin-bottom: 12px;
      color: #fff;
    }
    .contact-box p {
      color: rgba(255, 255, 255, 0.7);
      margin-bottom: 20px;
    }
  </style>

  <!-- Hero -->
  <section class="faq-hero">
    <div class="container">
      <a href="/" class="back-link">← 返回首頁</a>
      <h1><span class="gradient-text">常見問題</span></h1>
      <p style="color: rgba(255,255,255,0.7); font-size: 1.125rem;">
        關於 ArcSign 的所有疑問，都能在這裡找到答案
      </p>
    </div>
  </section>

  <!-- FAQ Content -->
  <section class="faq-content">
    <div class="container">

      <!-- Category: Basic -->
      <div class="faq-category">
        <h2>基本問題</h2>
        <div class="faq-page-list">
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>ArcSign 是什麼？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>ArcSign 是一個<strong>免費的 USB 冷錢包應用程式</strong>。它將你的私鑰存儲在 USB 隨身碟上，而不是電腦硬碟中，大幅降低被惡意軟體竊取的風險。</p>
                <p>ArcSign 支援多條區塊鏈（Ethereum、BSC、Polygon 等），並透過 WalletConnect 讓你可以安全地連接到各種 dApp。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>ArcSign 和 MetaMask 有什麼不同？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>最大的差別在於<strong>私鑰存儲位置</strong>：</p>
                <p>• MetaMask 把私鑰存在電腦硬碟，任何能讀取檔案的惡意軟體都可能竊取</p>
                <p>• ArcSign 把私鑰存在 USB 隨身碟，拔掉就是冷錢包，攻擊者無法存取不存在的檔案</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>ArcSign 是硬體錢包等級嗎？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p><strong>不是，ArcSign 是「強化版軟體錢包」</strong>。核心差異是私鑰存在 USB 而不是電腦硬碟，拔掉 USB 後駭客無法存取。但簽名仍在電腦完成，無法達到硬體錢包的完全隔離。</p>
                <p><strong>定位：</strong>比 MetaMask 更安全，比硬體錢包更便宜（免費）。大額長期儲存建議搭配硬體錢包使用。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>支援哪些作業系統？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>目前支援 <strong>macOS</strong>（Intel 和 Apple Silicon）。Windows 和 Linux 版本即將推出。</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Category: Security -->
      <div class="faq-category">
        <h2>安全相關</h2>
        <div class="faq-page-list">
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>ArcSign 安全嗎？怎麼確保沒有後門？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>ArcSign 採用<strong>業界頂級的加密標準</strong>保護你的私鑰，安全性不輸專業級產品。</p>
                <p>最重要的是：<strong>私鑰永遠不會離開你的 USB 隨身碟</strong>，也不會傳送到任何伺服器。拔掉 USB，駭客就無法存取你的私鑰。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>如果 USB 壞掉或遺失怎麼辦？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>ArcSign 提供<strong>兩種備份方式</strong>：</p>
                <p>• <strong>助記詞備份</strong>：將 12 或 24 個英文單詞抄寫在紙上，多份異地保存。即使 USB 損壞，你可以用助記詞在 ArcSign 或任何支援 BIP39 的錢包恢復資產。</p>
                <p>• <strong>加密檔案備份</strong>：直接複製 USB 內的錢包資料夾到另一個 USB 或安全位置。檔案已加密，只有知道密碼的人才能使用。這種方式更方便，且不用擔心助記詞外洩。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>忘記密碼怎麼辦？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>ArcSign 不儲存你的密碼，所以<strong>無法幫你重設密碼</strong>。但如果你有備份助記詞，可以用助記詞重新匯入錢包並設定新密碼。</p>
                <p>這就是為什麼我們反覆強調備份助記詞的重要性。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>什麼是詐騙代幣過濾？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>有些詐騙者會空投假代幣到你的錢包，試圖誘騙你點擊惡意網站。ArcSign 會<strong>自動隱藏這些可疑代幣</strong>，只顯示已知的合法代幣。</p>
                <p>你隨時可以選擇查看被過濾的代幣。</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Category: Features -->
      <div class="faq-category">
        <h2>功能相關</h2>
        <div class="faq-page-list">
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>什麼是 WalletConnect？怎麼使用？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>WalletConnect 是一個<strong>開放協議</strong>，讓你的錢包可以安全連接到各種 dApp（如 Uniswap、OpenSea、PancakeSwap）。</p>
                <p>使用方式很簡單：在 dApp 選擇「WalletConnect」連接方式，然後在 ArcSign 中貼上連接連結即可。所有交易都會在 ArcSign 中確認，確保你的私鑰安全。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>ArcSign 支援哪些 dApp？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>ArcSign 透過 WalletConnect 支援<strong>所有主流 dApp</strong>，包括但不限於：</p>
                <p>• DEX：Uniswap、PancakeSwap、SushiSwap</p>
                <p>• NFT：OpenSea、Blur、LooksRare</p>
                <p>• DeFi：Aave、Compound、Lido</p>
                <p>只要 dApp 支援 WalletConnect 連接方式，你就可以使用 ArcSign。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>Swap 功能會收手續費嗎？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p><strong>目前完全免費！</strong>你只需支付區塊鏈網路的 Gas Fee。</p>
                <p>未來我們將推出「智能路由」功能，整合更多聚合器自動搜尋最佳交易路徑。該功能會收取<strong>固定的低手續費</strong>（非百分比），比其他軟體錢包收取 0.5%~1% 的交易手續費便宜許多。</p>
                <p>現有的基本 Swap 功能將<strong>維持免費</strong>。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>支援哪些區塊鏈？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>目前支援的區塊鏈包括：</p>
                <p>• Ethereum (ETH)</p>
                <p>• BNB Smart Chain (BSC)</p>
                <p>• Polygon (MATIC)</p>
                <p>• Arbitrum One</p>
                <p>• Optimism</p>
                <p>• Base</p>
                <p>我們會持續添加更多鏈的支援。</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Category: Membership -->
      <div class="faq-category">
        <h2>會員與付費</h2>
        <div class="faq-page-list">
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>免費版有什麼限制？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>免費版可以使用 <strong>1 個錢包</strong>，其他所有功能都完整開放：</p>
                <p>• USB 離線存儲</p>
                <p>• 多鏈支援</p>
                <p>• Token Swap</p>
                <p>• WalletConnect</p>
                <p>• 交易歷史</p>
                <p>對於大多數用戶來說，免費版已經足夠。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>Pro 會員的 NFT 是什麼？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>Pro 會員資格以 BSC 鏈上的 NFT 形式存在。購買後，NFT 會鑄造到你的錢包地址。</p>
                <p>這代表你的會員資格是<strong>真正屬於你的數位資產</strong>，可以轉讓、出售或保留。每個 NFT 增加 3 個錢包配額（1 NFT = 4 個錢包）。</p>
              </div>
            </div>
          </div>
          <div class="faq-page-item">
            <button class="faq-page-question">
              <span>如何購買 Pro 會員？</span>
              <span class="icon">+</span>
            </button>
            <div class="faq-page-answer">
              <div class="faq-page-answer-content">
                <p>在 ArcSign 應用程式中：</p>
                <p>1. 進入「設定」→「會員資格」</p>
                <p>2. 選擇要購買的 NFT 數量</p>
                <p>3. 使用 USDT (BSC) 完成支付</p>
                <p>4. NFT 會自動鑄造到你的錢包</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Box -->
      <div class="contact-box">
        <h3>找不到你的問題？</h3>
        <p>歡迎加入我們的社群，我們會盡快回覆你的問題</p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a href="#" class="btn btn-secondary">Telegram</a>
          <a href="#" class="btn btn-secondary">Discord</a>
          <a href="https://x.com/ArcSignWallet" target="_blank" rel="noopener" class="btn btn-secondary">Twitter</a>
        </div>
      </div>

    </div>
  </section>

  <script>
    // FAQ accordion functionality
    document.querySelectorAll('.faq-page-question').forEach(button => {
      button.addEventListener('click', () => {
        const item = button.parentElement;
        item?.classList.toggle('active');
      });
    });
  </script>
</BaseLayout>
