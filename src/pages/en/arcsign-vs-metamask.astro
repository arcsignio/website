    /* ===== Why Not Both ===== */
    .both-card {
        background: var(--gradient-hero);
        border: 1px solid var(--primary-dark);
        border-radius: var(--radius-lg);
        padding: 36px;
        margin: 28px 0;
    }
    .both-card h3 {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--text-primary);
