                        <td class="check">Yes (stETH, ankrETH, ankrBNB + APY)</td>
                        <td class="warn">Limited (via Portfolio app)</td>
                    </tr>
                    <tr>
                        <td>NFT Gallery</td>
                        <td class="check">Yes (ERC721 + ERC1155)</td>
                        <td class="check">Yes</td>
                    </tr>
