    }
    .both-strategy {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-top: 20px;
    }
    .strategy-item {
        background: rgba(15,23,42,0.5);
        border-radius: var(--radius-md);
        padding: 18px 20px;
    }
    .strategy-item .strat-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        margin-bottom: 8px;
    }
    .strategy-item .strat-label.teal { color: var(--primary); }
    .strategy-item .strat-label.orange { color: #f6851b; }
    .strategy-item p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }

    /* ===== FAQ ===== */
    .faq-list { margin: 28px 0; }
    .faq-item {
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
