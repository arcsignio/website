    }
    .comp-table th {
        padding: 14px 18px;
        text-align: left;
        font-weight: 700;
        font-size: 0.88rem;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        border-bottom: 2px solid var(--border-color);
    }
    .comp-table th:first-child { color: var(--text-muted); }
    .comp-table th.col-arcsign { color: var(--primary); }
    .comp-table th.col-metamask { color: #f6851b; }
    .comp-table td {
        padding: 12px 18px;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-secondary);
        vertical-align: top;
