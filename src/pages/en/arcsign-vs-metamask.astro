    .verdict-card h3 {
        font-size: 1.15rem;
        font-weight: 800;
        margin-bottom: 6px;
    }
    .verdict-card.arcsign h3 { color: var(--primary); }
    .verdict-card.metamask h3 { color: #f6851b; }
    .verdict-card .verdict-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-muted);
