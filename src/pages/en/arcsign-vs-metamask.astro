        background: rgba(45,212,191,0.12);
        color: var(--primary);
        padding: 2px 10px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 12px;
    }

    /* ===== Quick Verdict ===== */
    .verdict-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin: 40px 0;
    }
    .verdict-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
