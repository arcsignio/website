        flex-shrink: 0;
        margin-top: 1px;
    }
    .verdict-card.metamask ul li::before { color: #f6851b; }

    /* ===== Section headings ===== */
    .section-h2 {
        font-size: 1.7rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-top: 64px;
        margin-bottom: 16px;
        padding-bottom: 12px;
        border-bottom: 2px solid var(--border-color);
    }
    .section-h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--primary);
        margin-top: 32px;
        margin-bottom: 12px;
    }
    .prose {
        color: var(--text-secondary);
        line-height: 1.8;
        font-size: 1.02rem;
        margin-bottom: 16px;
    }
