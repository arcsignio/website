    .use-card.use-arcsign h3 { color: var(--primary); }
    .use-card.use-metamask h3 { color: #f6851b; }
    .use-card ul { list-style: none; padding: 0; }
    .use-card ul li {
        font-size: 0.92rem;
        color: var(--text-secondary);
        padding: 6px 0;
        display: flex;
        gap: 8px;
