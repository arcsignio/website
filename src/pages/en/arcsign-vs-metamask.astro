    /* ===== Comparison Table ===== */
    .table-wrap {
        overflow-x: auto;
        margin: 28px 0;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-color);
    }
    .comp-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.92rem;
        min-width: 560px;
    }
    .comp-table thead tr {
