---
// English homepage — served at /en/
import BaseLayout from '../../layouts/BaseLayout.astro';

const locale = 'en' as const;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'ArcSign',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'macOS, Windows, Linux',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    description: 'Free USB cold wallet. Store private keys on USB drive - unplug it and it becomes a cold wallet. Supports WalletConnect to connect all dApps.',
    url: 'https://arcsign.io/en/',
    downloadUrl: 'https://github.com/arcsignio/arcsign/releases/latest',
    softwareVersion: '1.4.0',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'ArcSign',
    url: 'https://arcsign.io',
    logo: 'https://arcsign.io/assets/logo.png',
    description: 'ArcSign is a free USB cold wallet application for secure multi-chain cryptocurrency storage.',
    sameAs: [
      'https://x.com/ArcSignWallet',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'ArcSign',
    url: 'https://arcsign.io/',
    inLanguage: ['en', 'zh-TW'],
    publisher: {
      '@type': 'Organization',
      name: 'ArcSign',
      url: 'https://arcsign.io',
    },
  },
];
---

<BaseLayout
  title="ArcSign - Free USB Cold Wallet | Unplug to Secure, Connect All dApps"
  description="ArcSign is a free USB cold wallet. Store your private keys on a USB drive - unplug it and it becomes a cold wallet. Supports WalletConnect to connect Uniswap, OpenSea, and all dApps. No need to spend $100 on a hardware wallet."
  locale={locale}
  canonical="https://arcsign.io/en/"
  schema={schema}
>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badges">
          <span class="hero-badge-item">Portable Wallet</span>
          <span class="hero-badge-item">Zero Extra Cost</span>
          <span class="hero-badge-item">WalletConnect</span>
        </div>
        <h1><span>Your Assets, </span><span class="gradient-text">Your Control</span></h1>
        <p class="hero-subtitle">
          No device lock-in, no company dependency, no extra cost.<br />
          App + private keys all on USB, use on any computer.
        </p>
        <p class="hero-note">
          True plug-and-play — Unplug to stay safe
        </p>
        <div class="hero-cta">
          <a href="#download" class="btn btn-primary btn-lg">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            <span>Free Download</span>
          </a>
          <a href="#security" class="btn btn-secondary btn-lg">Learn About Security</a>
        </div>
        <!-- Three cards: core selling points -->
        <div class="hero-features">
          <div class="hero-feature-card">
            <span class="feature-icon-sm">🔓</span>
            <div>
              <strong>No Device Lock-in</strong>
              <p>Use on any computer</p>
            </div>
          </div>
          <div class="hero-feature-card">
            <span class="feature-icon-sm">🏛️</span>
            <div>
              <strong>No Company Dependency</strong>
              <p>Keys only in your hands</p>
            </div>
          </div>
          <div class="hero-feature-card">
            <span class="feature-icon-sm">💸</span>
            <div>
              <strong>No Extra Cost</strong>
              <p>Use existing USB</p>
            </div>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="app-preview">
          <div class="preview-header">
            <div class="window-controls">
              <span class="control red"></span>
              <span class="control yellow"></span>
              <span class="control green"></span>
            </div>
            <span class="preview-title">ArcSign</span>
          </div>
          <div class="preview-content">
            <div class="wallet-card">
              <div class="wallet-icon">🔐</div>
              <div class="wallet-info">
                <span class="wallet-name">My Wallet</span>
                <span class="wallet-balance">$12,450.00</span>
              </div>
            </div>
            <div class="chain-list">
              <div class="chain-item">
                <span class="chain-logo eth"></span>ETH
                <span class="chain-value">2.5</span>
              </div>
              <div class="chain-item">
                <span class="chain-logo bnb"></span>BNB
                <span class="chain-value">15.2</span>
              </div>
              <div class="chain-item">
                <span class="chain-logo matic"></span>MATIC
                <span class="chain-value">1,200</span>
              </div>
            </div>
            <div class="action-buttons">
              <button class="action-btn">Send</button>
              <button class="action-btn">Receive</button>
              <button class="action-btn primary">Swap</button>
            </div>
          </div>
        </div>
        <div class="usb-indicator">
          <div class="usb-icon">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <rect x="4" y="4" width="16" height="16" rx="2"></rect>
              <path d="M9 4V2"></path>
              <path d="M15 4V2"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </div>
          <span>Private keys stored safely on USB</span>
        </div>
      </div>
    </div>
    <div class="hero-bg"></div>
  </section>

  <!-- Problem Section -->
  <section class="problem">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Why ArcSign?</span>
        <h2><span>Software Wallet's </span><span class="text-danger">Fatal Flaw</span></h2>
      </div>
      <div class="problem-grid">
        <div class="problem-card">
          <div class="problem-icon">🦠</div>
          <h3>Keys on Hard Drive</h3>
          <p>
            MetaMask stores keys on your hard drive.<br />
            Malware can scan and steal 24/7.
          </p>
          <div class="problem-stat">
            <span class="stat-bad">File exists = Can be stolen</span>
          </div>
        </div>
        <div class="problem-card">
          <div class="problem-icon">💸</div>
          <h3>Hardware Wallets Too Expensive</h3>
          <p>
            Ledger/Trezor costs $79-149.<br />
            Many know it's safer but find it too pricey.
          </p>
          <div class="problem-stat">
            <span class="stat-bad">High barrier = Won't upgrade</span>
          </div>
        </div>
        <div class="problem-card">
          <div class="problem-icon">🔗</div>
          <h3>The Dilemma</h3>
          <p>
            Software wallets are convenient but insecure.<br />
            Hardware wallets are secure but expensive.
          </p>
          <div class="problem-stat">
            <span class="stat-bad">ArcSign = The Middle Ground</span>
          </div>
        </div>
      </div>

      <!-- Comparison Links -->
      <div style="display:flex; gap:16px; justify-content:center; margin-top:40px; flex-wrap:wrap;">
        <a href="/en/arcsign-vs-metamask" style="display:flex; align-items:center; gap:12px; background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:16px 24px; text-decoration:none; transition:border-color 0.2s, transform 0.2s;" onmouseover="this.style.borderColor='var(--primary)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='var(--border-color)';this.style.transform='translateY(0)'">
          <span style="font-size:1.5rem;">🦊</span>
          <div>
            <div style="font-weight:700; color:var(--text-primary); font-size:0.95rem;">ArcSign vs MetaMask</div>
            <div style="font-size:0.82rem; color:var(--text-muted); margin-top:2px;">Cold wallet vs hot wallet — full comparison →</div>
          </div>
        </a>
        <a href="/en/arcsign-vs-ledger" style="display:flex; align-items:center; gap:12px; background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:16px 24px; text-decoration:none; transition:border-color 0.2s, transform 0.2s;" onmouseover="this.style.borderColor='var(--primary)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='var(--border-color)';this.style.transform='translateY(0)'">
          <span style="font-size:1.5rem;">🔐</span>
          <div>
            <div style="font-weight:700; color:var(--text-primary); font-size:0.95rem;">ArcSign vs Ledger</div>
            <div style="font-size:0.82rem; color:var(--text-muted); margin-top:2px;">Free USB vs $79 hardware wallet →</div>
          </div>
        </a>
      </div>

    </div>
  </section>

  <!-- Solution Section -->
  <section class="solution" id="security">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">ArcSign Security Design</span>
        <h2><span class="gradient-text">USB Isolation</span><span> = Unplug to Stay Safe</span></h2>
        <p class="section-desc">
          Bringing hardware wallet's core concept to everyone, at zero cost
        </p>
      </div>

      <!-- Core Concepts -->
      <div class="defense-layers">
        <div class="defense-layer highlight">
          <div class="layer-number">1</div>
          <div class="layer-content">
            <h3>USB-only Storage</h3>
            <p class="layer-desc">Private keys not on hard drive</p>
            <ul class="layer-details">
              <li>Keys stored only on USB drive</li>
              <li>Unplug USB = Hackers can't find keys</li>
              <li>Malware can't steal non-existent files</li>
            </ul>
          </div>
        </div>
        <div class="defense-layer">
          <div class="layer-number">2</div>
          <div class="layer-content">
            <h3>Memory Hardening</h3>
            <p class="layer-desc">Memory-level protection</p>
            <ul class="layer-details">
              <li>mlock prevents swap to disk</li>
              <li>SecureZero clears after use</li>
              <li>Split key storage increases theft difficulty</li>
            </ul>
          </div>
        </div>
        <div class="defense-layer">
          <div class="layer-number">3</div>
          <div class="layer-content">
            <h3>Password Never Stored</h3>
            <p class="layer-desc">Re-enter for every operation</p>
            <ul class="layer-details">
              <li>Password never stored anywhere</li>
              <li>Session token time control</li>
              <li>Auto-lock when idle</li>
            </ul>
          </div>
        </div>
        <div class="defense-layer">
          <div class="layer-number">4</div>
          <div class="layer-content">
            <h3>Encrypted Backup</h3>
            <p class="layer-desc">Safer than seed phrases</p>
            <ul class="layer-details">
              <li>Just copy the wallet folder</li>
              <li>Safe to store in cloud</li>
              <li>Even we can't decrypt</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="security-note">
        <p>
          <strong>Honest Disclosure:</strong> ArcSign is an "enhanced software wallet", not a hardware wallet.
          Signing still happens on computer, but storing keys on USB greatly reduces theft risk.
          For large long-term storage, consider pairing with a hardware wallet.
        </p>
      </div>

      <div class="security-roadmap">
        <div class="roadmap-content">
          <div class="roadmap-icon">🚀</div>
          <div class="roadmap-text">
            <p class="roadmap-next">
              <strong>Roadmap:</strong> Transaction decoding, Risk warnings, Hardware-backed Signing
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Full Features</span>
        <h2>
          <span>Not just a wallet, a complete </span><span class="gradient-text">DeFi Toolbox</span>
        </h2>
      </div>
      <div class="features-grid">
        <div class="feature-card featured full-width">
          <div class="feature-icon">🔌</div>
          <h3>Plug &amp; Play — Take Your Wallet</h3>
          <p>App and wallet data all on USB, use on any computer. Unplug USB to stay safe, keys don't stay on computer.</p>
          <div class="feature-badge">Core Feature</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌐</div>
          <h3>WalletConnect Support</h3>
          <p>Connect to Uniswap, OpenSea, PancakeSwap and all major dApps</p>
          <div class="feature-badge">New Feature</div>
        </div>
        <a href="/en/developer" class="feature-card" style="text-decoration: none; color: inherit;">
          <div class="feature-icon">🔧</div>
          <h3>Developer Mode</h3>
          <p>For smart contract developers — Hardhat integration, secure signing, API key auto-injection</p>
          <div class="feature-badge">New</div>
          <span style="color: #2dd4bf; font-size: 0.9rem; margin-top: 8px; display: block;">Learn more →</span>
        </a>
        <div class="feature-card">
          <div class="feature-icon">🔗</div>
          <h3>Multi-chain Support</h3>
          <p>Bitcoin + 6 major EVM chains — covers most everyday assets</p>
          <div class="feature-chains">
            <span class="chain-badge eth">BTC</span>
            <span class="chain-badge eth">ETH</span>
            <span class="chain-badge bnb">BSC</span>
            <span class="chain-badge matic">Polygon</span>
            <span class="chain-badge arb">Arbitrum</span>
            <span class="chain-badge op">Optimism</span>
            <span class="chain-badge base">Base</span>
          </div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🛡️</div>
          <h3>Scam Token Filter</h3>
          <p>Auto-detect and hide scam tokens, only show verified tokens</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💾</div>
          <h3>Encrypted Backup</h3>
          <p>Safer than seed phrases — just copy folder, safe for cloud, even we can't decrypt</p>
          <div class="feature-badge">Exclusive</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💱</div>
          <h3>Token Swap</h3>
          <p>Aggregates multiple DEXes to automatically find the best route</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔑</div>
          <h3>Password Never Stored</h3>
          <p>Your password is never saved, re-enter for every operation</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📜</div>
          <h3>Transaction History</h3>
          <p>Complete transaction records and asset overview</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⏰</div>
          <h3>Auto Lock</h3>
          <p>Auto logout when idle, prevent unauthorized access</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Portfolio Overview</h3>
          <p>Real-time balance and valuation across all chains</p>
        </div>
      </div>
    </div>
  </section>

  <!-- For Everyone Section -->
  <section class="for-everyone">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Who Is It For</span>
        <h2><span>Designed for </span><span class="gradient-text">Everyone</span><span></span></h2>
        <p class="section-desc">
          Secure crypto storage shouldn't be a privilege
        </p>
      </div>
      <div class="everyone-grid">
        <div class="everyone-card">
          <div class="everyone-icon">🌍</div>
          <div class="everyone-card-content">
            <h3>Global Users</h3>
            <p>Whether in Taipei, Tokyo, or Dubai, just need a USB to securely store assets. No regional limits, no international shipping.</p>
          </div>
        </div>
        <div class="everyone-card">
          <div class="everyone-icon">💼</div>
          <div class="everyone-card-content">
            <h3>Beginners</h3>
            <p>No need to spend $100 on hardware wallet, get better security than software wallets. Zero barrier to start DeFi.</p>
          </div>
        </div>
        <div class="everyone-card">
          <div class="everyone-icon">🚀</div>
          <div class="everyone-card-content">
            <h3>Power Users</h3>
            <p>WalletConnect to all dApps, Swap, Staking features included. Full features, no compromise on security.</p>
          </div>
        </div>
        <div class="everyone-card">
          <div class="everyone-icon">✈️</div>
          <div class="everyone-card-content">
            <h3>Always Mobile</h3>
            <p>Take your wallet abroad, switch computers, handle any situation. Your assets always in your control, not tied to any device.</p>
          </div>
        </div>
      </div>
      <div class="everyone-mission">
        <p>
          We believe <strong>secure crypto storage shouldn't be a privilege for the wealthy</strong>.<br />
          Whatever your budget, ArcSign lets everyone use their existing USB drive for higher-level security.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="pricing" id="pricing">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Compare Plans</span>
        <h2><span>Choose Your </span><span class="gradient-text">Security Level</span></h2>
      </div>
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-header">
            <h3>Free</h3>
            <div class="price">
              <span class="price-value">$0</span>
              <span class="price-period">Forever Free</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li>USB Offline Storage</li>
            <li>1 Wallet</li>
            <li>Multi-chain Support</li>
            <li>Token Swap</li>
            <li>Transaction History</li>
            <li>Auto Lock</li>
          </ul>
          <a href="#download" class="btn btn-secondary btn-block">Free Download</a>
        </div>
        <div class="pricing-card featured">
          <div class="pricing-badge">Recommended</div>
          <div class="pricing-header">
            <h3>Pro</h3>
            <div class="price">
              <span class="price-value">$30</span>
              <span class="price-period">USDT / year</span>
            </div>
          </div>
          <ul class="pricing-features">
            <li><strong>All Free Features</strong></li>
            <li><strong>4+ Wallets</strong><span> (+3 per NFT)</span></li>
            <li>Batch revoke Token Approvals</li>
            <li>Priority Support</li>
            <li>Early Access to New Features</li>
          </ul>
          <a href="#download" class="btn btn-primary btn-block">Upgrade to Pro</a>
        </div>
        <div class="pricing-card compare">
          <div class="pricing-header">
            <h3>Hardware Wallet</h3>
            <div class="price">
              <span class="price-value">$79-149</span>
              <span class="price-period">One-time</span>
            </div>
          </div>
          <ul class="pricing-features muted">
            <li class="con">Need to buy device</li>
            <li class="con">Need software on computer</li>
            <li class="con">Setup again on new computer</li>
            <li class="con">Hard to buy in some regions</li>
            <li class="pro">Complete key isolation</li>
            <li class="highlight">Best for large long-term storage</li>
          </ul>
          <div class="pricing-note">Complementary to ArcSign</div>
        </div>
      </div>
      <div class="use-case-section">
        <div class="use-case-header">
          <h3>How to Use Together?</h3>
          <p>ArcSign and hardware wallets have different strengths, complementary not competing</p>
        </div>
        <div class="use-case-cards">
          <div class="use-case-card arcsign">
            <div class="use-case-icon">🔄</div>
            <div class="use-case-content">
              <h4>Daily DeFi Activity</h4>
              <p class="use-case-product">Recommended: ArcSign</p>
              <ul class="use-case-benefits">
                <li>Free to use</li>
                <li>Plug &amp; play, any computer</li>
                <li>Safer than software wallets</li>
              </ul>
            </div>
          </div>
          <div class="use-case-card hardware">
            <div class="use-case-icon">🏦</div>
            <div class="use-case-content">
              <h4>Large Long-term Storage</h4>
              <p class="use-case-product">Recommended: Hardware Wallet</p>
              <ul class="use-case-benefits">
                <li>Complete key isolation</li>
                <li>Highest security level</li>
                <li>Best for HODLing</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="use-case-roadmap">
          <span class="roadmap-badge">🔮 Coming Soon</span>
          <p>ArcSign will soon support <strong>hardware wallet integration</strong>, manage all assets in one interface</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Early Bird Section -->
  <!-- Newsletter Section -->
  <section class="newsletter" id="newsletter">
    <div class="container">
      <div class="newsletter-content">
        <h2>Stay in the Loop</h2>
        <p>Subscribe to the ArcSign newsletter for product updates, security guides, DeFi trends, and exclusive offers.</p>
        <form class="newsletter-form" id="newsletter-form">
          <input type="email" id="newsletter-email" placeholder="you@example.com" required autocomplete="email" />
          <button type="submit" class="btn btn-primary">Subscribe Free</button>
        </form>
        <p class="newsletter-status" id="newsletter-status"></p>
        <p class="newsletter-privacy">No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq" id="faq">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">FAQ</span>
        <h2>You Might Be Wondering</h2>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">
            <span>How is ArcSign different from MetaMask?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>
              The biggest difference is <strong>where private keys are stored</strong>. MetaMask
              stores keys on your hard drive, any malware that can read files might steal them. ArcSign
              stores keys on USB drive, unplug and it's a cold wallet, attackers can't access non-existent files.
            </p>
            <p style="margin-top:10px; margin-bottom:0;">
              <a href="/en/arcsign-vs-metamask" style="color:var(--primary); font-size:0.9rem; font-weight:600;">Full comparison: ArcSign vs MetaMask →</a>
            </p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>What if USB breaks or gets lost?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>ArcSign provides <strong>two backup methods</strong>:</p>
            <p><strong>Encrypted File Backup (Recommended)</strong>: Just copy the wallet folder from USB to another USB or cloud. Files are encrypted, only those with password can use it, no leak concerns.</p>
            <p><strong>Seed Phrase Backup</strong>: Write down 12 or 24 English words on paper. Can recover assets in any BIP39-compatible wallet.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Is ArcSign hardware wallet level?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p><strong>No, ArcSign is an "enhanced software wallet"</strong>. The key difference is private keys are on USB instead of hard drive, hackers can't access after unplugging. But signing still happens on computer, can't achieve hardware wallet's complete isolation.</p>
            <p><strong>Positioning:</strong> Safer than MetaMask, cheaper than hardware wallet (free). For large long-term storage, recommend pairing with hardware wallet.</p>
            <p style="margin-top:10px; margin-bottom:0;">
              <a href="/en/arcsign-vs-ledger" style="color:var(--primary); font-size:0.9rem; font-weight:600;">Full comparison: ArcSign vs Ledger →</a>
            </p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Is ArcSign secure? How to ensure no backdoors?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>ArcSign uses <strong>AES-256-GCM</strong> to encrypt the wallet files on your USB. Private keys never leave the drive and are never sent to any server. The source is published under Apache 2.0 on GitHub, so anyone can audit or reproduce the build: <a href="https://github.com/arcsignio/arcsign" style="color:var(--primary);">github.com/arcsignio/arcsign</a>.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>What is WalletConnect? How to use?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>WalletConnect is an <strong>open protocol</strong> that lets your wallet securely connect to various dApps (like Uniswap, OpenSea, PancakeSwap). Simple to use: select "WalletConnect" in dApp, then paste the connection link in ArcSign. All transactions confirmed in ArcSign, ensuring your keys stay safe.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>What is scam token filtering?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Some scammers airdrop fake tokens to your wallet, trying to lure you to malicious sites. ArcSign <strong>automatically hides these suspicious tokens</strong>, only showing known legitimate tokens. You can always choose to view filtered tokens.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Does Swap charge fees?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>ArcSign itself does not charge a swap fee — the aggregator (KyberSwap, 1inch) handles routing, and you pay the standard blockchain network Gas Fee. We compare multiple DEX aggregators automatically to find the best route.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Which operating systems are supported?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Supports <strong>macOS</strong> (Apple Silicon), <strong>Windows</strong> (x64), and <strong>Linux</strong> (x64). All three platforms available for download.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Which dApps does ArcSign support?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>ArcSign supports <strong>all major dApps</strong> via WalletConnect, including but not limited to: Uniswap, PancakeSwap, SushiSwap, OpenSea, Aave, Compound, etc. Any dApp supporting WalletConnect can be used with ArcSign.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>What is the Pro membership NFT?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Pro membership exists as an NFT on BSC chain. After purchase, NFT is minted to your wallet address. This means your membership is <strong>a digital asset that truly belongs to you</strong>, can be transferred, sold, or kept. Each NFT adds 3 wallet slots (1 NFT = 4 wallets).</p>
          </div>
        </div>
      </div>
    </div>
