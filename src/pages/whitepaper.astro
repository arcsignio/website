---
// zh-TW Whitepaper page — served at /whitepaper
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Whitepaper - ArcSign"
  description="ArcSign Technical Whitepaper - Deep dive into USB cold wallet security architecture and design philosophy."
  locale="zh-TW"
  canonical="https://arcsign.io/whitepaper"
>
  <style>
    .whitepaper-hero {
      padding: 120px 0 60px;
      background: linear-gradient(135deg, #0a0a0a 0%, #0f2b46 100%);
    }
    .whitepaper-hero h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    .coming-soon-section {
      padding: 100px 0;
      text-align: center;
    }
    .coming-soon-card {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 60px 40px;
      max-width: 600px;
      margin: 0 auto;
    }
    .coming-soon-icon {
      font-size: 4rem;
      margin-bottom: 24px;
    }
    .coming-soon-card h2 {
      font-size: 2rem;
      color: #fff;
      margin-bottom: 16px;
    }
    .coming-soon-card p {
      color: rgba(255, 255, 255, 0.7);
      font-size: 1.125rem;
      line-height: 1.8;
      margin-bottom: 24px;
    }
    .coming-soon-features {
      text-align: left;
      background: rgba(255, 255, 255, 0.03);
      border-radius: 12px;
      padding: 24px;
      margin: 32px 0;
    }
    .coming-soon-features h3 {
      color: #fff;
      font-size: 1rem;
      margin-bottom: 16px;
    }
    .coming-soon-features ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .coming-soon-features li {
      padding: 8px 0;
      color: rgba(255, 255, 255, 0.7);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .coming-soon-features li::before {
      content: "•";
      color: #2dd4bf;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      margin-bottom: 20px;
      transition: color 0.2s;
    }
    .back-link:hover {
      color: #fff;
    }
  </style>

  <!-- Hero -->
  <section class="whitepaper-hero">
    <div class="container">
      <a href="/" class="back-link" data-i18n="common.backHome">← 返回首頁</a>
      <h1><span class="gradient-text" data-i18n="whitepaper.title">ArcSign 白皮書</span></h1>
      <p style="color: rgba(255,255,255,0.7); font-size: 1.125rem;" data-i18n="whitepaper.subtitle">
        USB 冷錢包的安全架構與設計理念
      </p>
    </div>
  </section>

  <!-- Coming Soon Section -->
  <section class="coming-soon-section">
    <div class="container">
      <div class="coming-soon-card">
        <div class="coming-soon-icon">📄</div>
        <h2 data-i18n="whitepaper.coming.title">Coming Soon</h2>
        <p data-i18n="whitepaper.coming.desc">
          ArcSign 技術白皮書正在撰寫中，將詳細說明我們的安全架構、加密機制和設計理念。
        </p>

        <div class="coming-soon-features">
          <h3 data-i18n="whitepaper.coming.features.title">白皮書將涵蓋：</h3>
          <ul>
            <li data-i18n="whitepaper.coming.features.item1">USB 離線存儲的安全設計</li>
            <li data-i18n="whitepaper.coming.features.item2">加密演算法與密鑰派生機制</li>
            <li data-i18n="whitepaper.coming.features.item3">與傳統軟體錢包和硬體錢包的比較</li>
            <li data-i18n="whitepaper.coming.features.item4">已知限制與安全邊界說明</li>
            <li data-i18n="whitepaper.coming.features.item5">未來發展路線圖</li>
          </ul>
        </div>

        <p style="color: rgba(255,255,255,0.5); font-size: 0.875rem;" data-i18n="whitepaper.coming.staytuned">
          敬請期待
        </p>

        <a href="/" class="btn btn-secondary" style="margin-top: 20px;" data-i18n="whitepaper.coming.backhome">返回首頁</a>
      </div>
    </div>
  </section>
</BaseLayout>
